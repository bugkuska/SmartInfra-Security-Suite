    {
      "parameters": {
        "jsCode": "const stdout = items[0].json.stdout;\n\nconst lines = stdout.split(\"\\n\");\n\nconst hosts = [];\n\nfor (const line of lines) {\n\n  if (line.includes(\"Status: Up\")) {\n\n    const match = line.match(/Host:\\s+([0-9.]+)/);\n\n    if (match) {\n\n      hosts.push({\n        json: {\n          ip: match[1],\n          status: \"up\",\n          site: $input.first().json.site,\n          scan_profile: \"asset_discovery\"\n        }\n      });\n\n    }\n  }\n}\n\nreturn hosts;"
      },
