    {
      "parameters": {
        "command": "=set -e\n\nBASE_DIR=\"/root/n8n/local/discovery\"\nmkdir -p \"$BASE_DIR\"\n\nNET=\"{{ $json.network_range }}\"\n\n# แปลง subnet ให้ปลอดภัยสำหรับ filename\nSAFE_NET=$(echo \"$NET\" | tr '/.' '__')\n\nOUT_FILE=\"$BASE_DIR/discovery_${SAFE_NET}.gnmap\"\n\ndocker run --rm \\\n  instrumentisto/nmap:latest \\\n  nmap -sn \"$NET\" -oG - > \"$OUT_FILE\" || true\n\n# ส่งผลลัพธ์ออก stdout\ncat \"$OUT_FILE\""
      },
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [
        704,
        -336
      ],
      "id": "e706b2e8-8f24-46c5-a1e7-dfe1aa829728",
      "name": "SSH | Run Nmap Discovery Scan",
      "credentials": {
        "sshPassword": {
          "id": "uYKIdMbOjxSmRPTd",
          "name": "SSH Password account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = items[0].json;\n\nconst network = data.network_range;\n\nif (!network) {\n  throw new Error(\"network_range is missing\");\n}\n\n// ตรวจรูปแบบ subnet เช่น 192.168.1.0/24\nconst subnetRegex = /^(\\d{1,3}\\.){3}\\d{1,3}\\/\\d{1,2}$/;\n\nif (!subnetRegex.test(network)) {\n  throw new Error(\"Invalid network_range format\");\n}\n\n// ป้องกันค่าแปลก\nif (network.length > 25) {\n  throw new Error(\"network_range too long\");\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        512,
        -336
      ],
      "id": "451a54f2-aa69-4f2d-b30b-59e9ea7481c3",
      "name": "CODE | Validate Scan Input"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// SmartInfra Normalize Asset Data\n\nconst site = \"SmartInfra-LAB\";\nconst scan_profile = \"asset_discovery\";\nconst source = \"nmap-scan\";\n\n// เวลาไทย Asia/Bangkok\nconst scan_time = new Date().toLocaleString(\"sv-SE\", {\n  timeZone: \"Asia/Bangkok\"\n}).replace(\" \", \"T\").replace(\"T\", \" \");\n\nconst ip = $json.ip;\nconst status = $json.status || \"unknown\";\n\nconst row_key = `${site}_${ip}`;\n\nreturn {\n  row_key: row_key,\n  ip: ip,\n  status: status,\n  site: site,\n  scan_profile: scan_profile,\n  asset_name: ip,\n  asset_type: \"unknown\",\n  source: source,\n  discovered_at: scan_time,\n  last_seen: scan_time,\n  scan_time: scan_time\n};"
      },
