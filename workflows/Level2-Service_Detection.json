    {
      "parameters": {
        "jsCode": "function cleanText(v) {\n  return String(v || \"\").replace(/\\s+/g, \" \").trim();\n}\n\nfunction serviceLabel(service, port) {\n  const s = String(service || \"\").toLowerCase();\n\n  if (s === \"ssh\" || port === 22) return \"SSH\";\n  if (s === \"domain\" || port === 53) return \"DNS\";\n  if (s.includes(\"http\") || [80, 8080, 8008].includes(port)) return \"HTTP\";\n  if (s.includes(\"ssl\") || s.includes(\"https\") || [443, 8443].includes(port)) return \"HTTPS\";\n  if (s === \"rtsp\" || port === 554) return \"RTSP\";\n  if (s === \"rpcbind\" || port === 111) return \"RPCBIND\";\n  if ([135, 139, 445].includes(port)) return \"SMB/RPC\";\n  if (port === 3000) return \"APP\";\n  return String(service || \"\").toUpperCase();\n}\n\nfunction detectProduct(version) {\n  const v = String(version || \"\");\n\n  if (/dropbear/i.test(v)) return \"Dropbear SSH\";\n  if (/openssh/i.test(v)) return \"OpenSSH\";\n  if (/apache/i.test(v)) return \"Apache HTTP Server\";\n  if (/nginx/i.test(v)) return \"Nginx\";\n  if (/microsoft-iis/i.test(v)) return \"Microsoft IIS\";\n  if (/node/i.test(v)) return \"Node.js App\";\n  if (/dns/i.test(v)) return \"DNS Service\";\n\n  return \"\";\n}\n\nconst out = [];\n\nfor (const item of items) {\n  const ip = cleanText(item.json.ip);\n  const port = Number(item.json.port || 0);\n  const protocol = \"tcp\";\n  const service = cleanText(item.json.service).toLowerCase();\n  const version = cleanText(item.json.version);\n  const raw_line = cleanText(item.json.raw_line);\n\n  const service_name = serviceLabel(service, port);\n  const product = detectProduct(version);\n\n  out.push({\n    json: {\n      ip,\n      port,\n      protocol,\n      service,\n      service_name,\n      product,\n      version,\n      raw_line,\n      exposed: true\n    }\n  });\n}\n\nreturn out;"
      },
