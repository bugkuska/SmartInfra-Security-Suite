    {
      "parameters": {
        "jsCode": "const hosts = {};\n\nfor (const item of items) {\n\n  const ip = item.json.ip;\n  const port = item.json.port;\n\n  if (!hosts[ip]) {\n    hosts[ip] = [];\n  }\n\n  hosts[ip].push(port);\n}\n\nconst results = [];\n\nfor (const ip in hosts) {\n\n  results.push({\n    json: {\n      ip: ip,\n      ports: hosts[ip].join(\",\")\n    }\n  });\n\n}\n\nreturn results;"
      },
