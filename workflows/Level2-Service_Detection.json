    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of items) {\n  const stdout = item.json.stdout || \"\";\n  if (!stdout) continue;\n\n  // หา IP\n  const ipMatch = stdout.match(/Nmap scan report for\\s+([0-9.]+)/);\n  const ip = ipMatch ? ipMatch[1] : null;\n\n  // แยกบรรทัด\n  const lines = stdout.split(\"\\n\");\n\n  for (const line of lines) {\n    // จับบรรทัด port/service/version\n    // ตัวอย่าง:\n    // 22/tcp open  ssh     Dropbear sshd 2019.78 (protocol 2.0)\n    // 53/tcp open  domain  (generic dns response: NXDOMAIN)\n    const m = line.match(/^(\\d+)\\/tcp\\s+open\\s+(\\S+)\\s*(.*)$/);\n\n    if (m) {\n      const port = Number(m[1]);\n      const service = m[2] || \"\";\n      const version = (m[3] || \"\").trim();\n\n      results.push({\n        json: {\n          ip,\n          port,\n          service,\n          version,\n          raw_line: line.trim()\n        }\n      });\n    }\n  }\n}\n\nreturn results;"
      },
