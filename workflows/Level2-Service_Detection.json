    {
      "parameters": {
        "jsCode": "const nowUTC = new Date().toISOString();\nconst nowTH = new Date().toLocaleString(\"sv-SE\", { timeZone: \"Asia/Bangkok\" });\n\nreturn items.map(item => {\n\n  const ip = item.json.ip;\n  const port = item.json.port;\n  const protocol = item.json.protocol;\n\n  const row_key = `${ip}_${port}_${protocol}`;\n\n  return {\n    json: {\n      row_key,\n      ip,\n      port,\n      protocol,\n      service: item.json.service,\n      service_name: item.json.service_name,\n      product: item.json.product,\n      version: item.json.version,\n      exposed: item.json.exposed,\n      first_seen: nowTH,\n      last_seen: nowTH,\n      scan_time_utc: nowUTC,\n      scan_time_th: nowTH\n    }\n  };\n});"
      },
